{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cppbuild",//tipo da configuração 
			"label": "Compilar",//nome do arquivo
			"command": "c++",//nome de compilação
			"args": [
				"-fdiagnostics-color=always",//feedback colorido
				"-g",//para depuração de código
				"main.cpp",//É ESSE DANADO QUE EXECUTA.caso ${file},vai executar o arquivo aberto
				"-o",//tipo do programa que vai ser gerado
				"./main"//caso ${fileDirname}/${fileBasenameNoExtension} coloca o executável como nome do arquivo sem extenção
			],
			"options": {
				"cwd": "${workspaceFolder}"//qual o diretório que executa esse comando. Caso fileDirname pega o diretório do arquivo aberto, caso workspaceFolder vai executar de qualquer lugar do projeto
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",//fala que é uma tarefa de compilação
			"detail": "compiler: /usr/bin/g++"
		}
	]
}